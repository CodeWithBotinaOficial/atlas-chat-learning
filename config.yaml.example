# Model configuration parameters
model:
  # Dimension of the embedding space for tokens.
  embed_dim: 256
  # Number of attention heads in the multi-head attention mechanism.
  num_heads: 8
  # Dimension of the feed-forward network in the Transformer blocks.
  ff_dim: 1024
  # Number of Transformer encoder/decoder layers.
  num_layers: 6
  # Maximum sequence length the model can handle.
  max_seq_len: 512
  # Dropout rate for regularization to prevent overfitting.
  dropout_rate: 0.1

# Training configuration parameters
training:
  # Initial learning rate for the optimizer.
  learning_rate: 0.0003
  # Rate at which the learning rate decays over time.
  lr_decay_rate: 0.95
  # Number of steps after which the learning rate decays.
  lr_decay_steps: 100
  # Maximum size of the replay buffer for experience replay.
  replay_buffer_size: 200
  # Proportion of samples to draw from the replay buffer during training.
  replay_sample_rate: 0.3
  # Adam optimizer parameters (optional; currently hardcoded in transformer.py).
  beta1: 0.9
  beta2: 0.999
  epsilon: 1.0e-8
  warmup_steps: 10
  # Number of epochs to train when using --file or --url
  epochs: 50
  # Maximum characters per chunk for text splitting
  chunk_size: 1000
  # Interval (in interactions) for NaN weight checks
  nan_check_interval: 10
  # Interval (in interactions) for auto-saving the model
  auto_save_interval: 5

# Text generation configuration parameters
generation:
  # Controls the randomness of predictions. Lower values make the model more deterministic.
  temperature: 0.3
  # Penalizes repeated tokens to encourage diverse responses.
  repetition_penalty: 1.2
  # Limits the sampling pool to the top K most likely next tokens.
  top_k: 40
  # Limits the sampling pool to the smallest set of tokens whose cumulative probability exceeds P.
  top_p: 0.95
  # Number of beams to use for beam search decoding (0 disables beam search for faster generation).
  beam_width: 0
  # Maximum number of new tokens to generate in a response.
  max_new_tokens: 50
  # fast_mode: false  # Use CLI flag --fast with --production for low-latency greedy decoding.

# Memory management configuration parameters
memory:
  # Maximum number of previous turns to keep in the conversation history.
  max_history_length: 15

# Web scraping configuration parameters
scraping:
  # Timeout for establishing the connection in seconds.
  connect_timeout: 5
  # Timeout for receiving a response in seconds.
  read_timeout: 30
  # Number of retry attempts for a failed request.
  max_retries: 3
  # A base number for the exponential backoff calculation (e.g., wait time = backoff_factor * (2 ** retry_count)).
  backoff_factor: 1

# Performance optimization parameters
performance:
  # If true, overrides model and generation settings to save RAM
  low_memory: false
  # Use float16 for model weights (reduces memory by ~50%)
  half_precision: false
  # Optional: auto-adjust model if RAM is limited (future)
  max_ram_gb: null

# Model training analytics reporting parameters
reporting:
  # If true, records training metrics and generates a report on exit
  enabled: true
  # Directory where reports are saved
  output_dir: .reports/statistics
  # If true, compiles visual plots using matplotlib into a PDF report
  generate_graphs: true
  # Maximum history points to store in memory (avoids memory leak over long runs)
  max_history_points: 1000